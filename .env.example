# Core runtime
AUTH_PROVIDER=supabase

# Supabase auth
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional extraction/enrichment providers
ZYTE_API_KEY=
OPENAI_API_KEY=
OPENAI_ITEM_NAME_MODEL=gpt-4.1-mini
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_ITEM_NAME_TIMEOUT_MS=6000

# Optional feedback email delivery (Resend)
RESEND_API_KEY=
FEEDBACK_EMAIL_TO=
FEEDBACK_EMAIL_FROM=ShopBoard Feedback <onboarding@resend.dev>

# Optional session tuning
SESSION_MAX_AGE_SECONDS=3888000
